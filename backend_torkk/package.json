{
  "name": "backend_torkk",
  "version": "2.0.0",
  "description": "Torkkk Marketing Website & Admin CMS — Backend API (PostgreSQL + Prisma)",
  "main": "server.js",
  "scripts": {
    "dev": "npx nodemon server.js",
    "start": "node server.js",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:migrate:prod": "node node_modules/prisma/build/index.js migrate deploy",
    "db:push": "node node_modules/prisma/build/index.js db push",
    "db:generate": "node node_modules/prisma/build/index.js generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "node node_modules/prisma/build/index.js studio",
    "db:reset": "node node_modules/prisma/build/index.js migrate reset"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^6.12.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.0.1",
    "nodemailer": "^7.0.3",
    "pg": "^8.22.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "prisma": "^6.12.0"
  }
}
