# ================================
# SERVER
# ================================
NODE_ENV=development
PORT=5000

# ================================
# DATABASE (Neon PostgreSQL)
# ================================
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require

# ================================
# JWT
# ================================
JWT_ACCESS_SECRET=your_jwt_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ================================
# SECURITY
# ================================
CORS_ORIGIN=http://localhost:3000
BCRYPT_ROUNDS=12

# ================================
# EMAIL (Nodemailer)
# ================================
# Company/admin notification email
COMPANY_EMAIL=admin@yourcompany.com
# From address used in outgoing emails
EMAIL_FROM=noreply@yourcompany.com
# SMTP credentials
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password

# ================================
# UPLOADS / STORAGE
# ================================
# Max file size in bytes (default 5MB)
MAX_FILE_SIZE=5242880
# Set to 'local' or 'cloud'
UPLOAD_PROVIDER=local
# Cloud storage (AWS S3, Cloudinary, etc.)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ================================
# ADMIN SEED (for initial SUPER_ADMIN)
# ================================
SEED_ADMIN_EMAIL=superadmin@yourcompany.com
SEED_ADMIN_PASSWORD=YourSecurePassword@2026!
SEED_ADMIN_NAME=Super Admin
